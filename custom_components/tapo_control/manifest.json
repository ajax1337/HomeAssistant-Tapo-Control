{
  "domain": "tapo_control",
  "name": "Tapo: Cameras Control",
  "documentation": "https://github.com/ajax1337/HomeAssistant-Tapo-Control",
  "issue_tracker": "https://github.com/ajax1337/HomeAssistant-Tapo-Control/issues",
  "codeowners": [
    "@JurajNyiri",
    "@ajax1337"
  ],
  "version": "7.1.16.8",
  "iot_class": "local_polling",
  "requirements": [
    "pytapo @ https://github.com/ajax1337/pytapo/archive/refs/tags/v3.4.15.post1.tar.gz",
    "python-kasa[speedups]==0.10.2"
  ],
  "dependencies": [
    "ffmpeg",
    "onvif",
    "stream",
    "network"
  ],
  "config_flow": true,
  "homeassistant": "2025.10.0",
  "dhcp": [
    {
      "hostname": "c[0-9][0-9][0-9]*_*"
    },
    {
      "hostname": "d[0-9][0-9][0-9]*_*"
    },
    {
      "hostname": "tc[0-9][0-9]*_*"
    },
    {
      "hostname": "d[0-9][0-9][0-9]*c_*"
    },
    {
      "hostname": "h[0-9][0-9][0-9]*_*"
    }
  ],
  "loggers": [
    "custom_components.tapo_control"
  ]
}